# API port (admin dashboard :3000, public site :3002 — point each at this URL)
PORT=3001
NODE_ENV=development

# Browser origins allowed for CORS — list EVERY frontend that calls this API from the browser.
# Include BOTH the admin app and the public/marketing site (contact form). Comma-separated, no trailing slashes.
# Local:
FRONTEND_URLS=http://localhost:3000,http://localhost:3002
# Production (example):
# FRONTEND_URLS=https://manufacturer-admin.vercel.app,https://your-public-site.vercel.app

# Optional: single origin instead of FRONTEND_URLS
# FRONTEND_URL=http://localhost:3002

# Neon / PostgreSQL — use sslmode=verify-full to match node-postgres defaults and avoid SSL deprecation warnings
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=verify-full

# Plain password the admin uses on POST /api/admin/login (choose a strong one)
ADMIN_PASSWORD=change-me

# Secret for signing JWTs (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret
